/* ==========================
   QUIZ
========================== */

const perguntas = [

{
pergunta:"Qual bioma é conhecido como berço das águas?",
opcoes:["Caatinga","Cerrado","Pampa","Pantanal"],
correta:1
},
{
pergunta:"O que significa ILPF?",
opcoes:[
"Integração Lavoura Pecuária Floresta",
"Irrigação Local para Fazendas",
"Índice de Produção Florestal",
"Instituto Legal de Produção"
],
correta:0
},
{
pergunta:"Quem criou tecnologias para o Cerrado?",
opcoes:[
"ONU",
"EMBRAPA",
"FAO",
"IBAMA"
],
correta:1
}

];

let perguntaAtual = 0;
let pontuacao = 0;

const quizQuestion =
document.getElementById("quizQuestion");

const quizOptions =
document.getElementById("quizOptions");

function carregarPergunta(){

 if(!quizQuestion) return;

 const atual =
 perguntas[perguntaAtual];

 quizQuestion.textContent =
 atual.pergunta;

 quizOptions.innerHTML = "";

 atual.opcoes.forEach(
 (opcao,index)=>{

 const btn =
 document.createElement("button");

 btn.className="quiz-option";
 btn.textContent=opcao;

 btn.onclick=()=>{

 if(index===atual.correta){
   pontuacao++;
 }

 perguntaAtual++;

 if(perguntaAtual <
 perguntas.length){
   carregarPergunta();
 }else{
   finalizarQuiz();
 }

 };

 quizOptions.appendChild(btn);

 });

}

function finalizarQuiz(){

 document
 .getElementById(
 "quizQuestionWrap"
 ).style.display="none";

 document
 .getElementById(
 "quizFinal"
 ).style.display="block";

 document
 .getElementById(
 "quizFinalScore"
 ).innerHTML =
 `${pontuacao}/${perguntas.length}`;

}

carregarPergunta();