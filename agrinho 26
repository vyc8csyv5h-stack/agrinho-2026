========================== */

const filtros =
document.querySelectorAll(".galeria__filtro");

const itens =
document.querySelectorAll(".galeria__item");

filtros.forEach(btn => {

  btn.addEventListener("click", () => {

    filtros.forEach(b =>
      b.classList.remove(
      "galeria__filtro--active"
    ));

    btn.classList.add(
    "galeria__filtro--active"
    );

    const filtro =
    btn.dataset.filtro;

    itens.forEach(item => {

      if(
        filtro === "todos" ||
        item.dataset.categoria === filtro
      ){
        item.style.display = "block";
      }else{
        item.style.display = "none";
      }

    });

  });

});

