* script.
/* ==========================================================
   RESET
   ========================================================== */

*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: "Source Sans 3", sans-serif;
  background: #f8faf8;
  color: #222;
  line-height: 1.7;
  overflow-x: hidden;
}

img {
  max-width: 100%;
  display: block;
}

a {
  text-decoration: none;
}

ul {
  list-style: none;
}

button {
  border: none;
  cursor: pointer;
  font-family: inherit;
}

:root {

  --primary: #1b7a3e;
  --primary-dark: #145b2f;
  --secondary: #ffc107;
  --secondary-dark: #e0a800;

  --blue: #0d6efd;
  --red: #dc3545;
  --orange: #fd7e14;

  --white: #ffffff;
  --black: #111111;

  --gray-100: #f8f9fa;
  --gray-200: #e9ecef;
  --gray-300: #dee2e6;
  --gray-400: #ced4da;
  --gray-500: #adb5bd;
  --gray-600: #6c757d;
  --gray-700: #495057;
  --gray-800: #343a40;
  --gray-900: #212529;

  --shadow-sm: 0 4px 12px rgba(0,0,0,.08);
  --shadow-md: 0 10px 30px rgba(0,0,0,.12);
  --shadow-lg: 0 20px 40px rgba(0,0,0,.18);

  --radius-sm: 8px;
  --radius-md: 16px;
  --radius-lg: 24px;

  --transition: all .35s ease;
}

.container {
  width: min(1200px, 92%);
  margin: auto;
}

.section {
  padding: 100px 0;
}

.section-header {
  text-align: center;
  max-width: 850px;
  margin: 0 auto 60px;
}

.section-eyebrow {
  color: var(--primary);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 12px;
}

.section-title {
  font-family: "Merriweather", serif;
  font-size: clamp(2rem, 5vw, 3.4rem);
  margin-bottom: 20px;
  color: var(--gray-900);
}

.section-desc {
  color: var(--gray-700);
  font-size: 1.1rem;
}

/* ==========================================================
   BOTÕES
   ========================================================== */

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 28px;
  border-radius: 50px;
  font-weight: 700;
  transition: var(--transition);
}

.btn--primary {
  background: var(--primary);
  color: white;
}

.btn--primary:hover {
  background: var(--primary-dark);
  transform: translateY(-3px);
}

.btn--outline {
  border: 2px solid white;
  color: white;
}

.btn--outline:hover {
  background: white;
  color: var(--primary);
}

/* ==========================================================
   NAVBAR
   ========================================================== */

.navbar {
  position: fixed;
  width: 100%;
  top: 0;
  z-index: 999;
  transition: var(--transition);
  background: rgba(0,0,0,.25);
  backdrop-filter: blur(10px);
}

.navbar.scrolled {
  background: rgba(10,20,10,.95);
}

.navbar__container {
  width: min(1300px, 95%);
  margin: auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 0;
}

.navbar__logo {
  display: flex;
  align-items: center;
  gap: 10px;
  color: white;
}

.navbar__logo-icon {
  font-size: 1.8rem;
}

.navbar__logo-text {
  font-size: 1.4rem;
  font-weight: 700;
}

.navbar__list {
  display: flex;
  gap: 28px;
}

.navbar__link {
  color: white;
  font-weight: 600;
  position: relative;
}

.navbar__link::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -6px;
  width: 0;
  height: 2px;
  background: var(--secondary);
  transition: .3s;
}

.navbar__link:hover::after {
  width: 100%;
}

.navbar__toggle {
  display: none;
  background: transparent;
}

.navbar__toggle-bar {
  display: block;
  width: 28px;
  height: 3px;
  margin: 5px;
  background: white;
  border-radius: 10px;
}

/* ==========================================================
   HERO
   ========================================================== */

.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;

  background:
    url("https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=1600&q=80")
    center/cover no-repeat;
}

.hero__overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(
      rgba(0,0,0,.55),
      rgba(0,0,0,.65)
    );
}

.hero__content {
  position: relative;
  z-index: 2;
  width: min(900px, 90%);
  color: white;
}

.hero__eyebrow {
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 18px;
  color: #ddd;
}

.hero__title {
  font-family: "Merriweather", serif;
  font-size: clamp(3rem, 7vw, 5.8rem);
  line-height: 1.1;
}

.hero__title--accent {
  color: var(--secondary);
}

.hero__subtitle {
  margin: 25px auto;
  max-width: 700px;
  font-size: 1.2rem;
}

.hero__actions {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
}

.hero__stats {
  position: absolute;
  bottom: 50px;
  display: flex;
  gap: 25px;
  flex-wrap: wrap;
  justify-content: center;
  z-index: 2;
}

.hero__stat {
  background: rgba(255,255,255,.12);
  backdrop-filter: blur(10px);
  padding: 18px;
  border-radius: 18px;
  min-width: 180px;
}

.hero__stat-number {
  display: block;
  font-size: 2rem;
  font-weight: 700;
  color: var(--secondary);
}

.hero__stat-label {
  color: white;
  font-size: .95rem;
}

.hero__scroll-arrow {
  position: absolute;
  bottom: 20px;
  z-index: 2;
  color: white;
  font-size: 2rem;
  animation: bounce 1.5s infinite;
}

@keyframes bounce {
  0%,100%{
    transform:translateY(0);
  }
  50%{
    transform:translateY(8px);
  }
}/* ==========================================================
   INTRODUÇÃO
   ========================================================== */

.intro {
  background: #ffffff;
}

.intro__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 30px;
}

.intro__card {
  background: white;
  padding: 35px;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
  border-top: 5px solid var(--primary);
}

.intro__card:hover {
  transform: translateY(-10px);
  box-shadow: var(--shadow-md);
}

.intro__card-icon {
  font-size: 3rem;
  margin-bottom: 20px;
}

.intro__card-title {
  font-size: 1.4rem;
  margin-bottom: 15px;
  color: var(--gray-900);
}

.intro__card-text {
  color: var(--gray-700);
}

/* ==========================================================
   IMPORTÂNCIA ECONÔMICA
   ========================================================== */

.importancia {
  background: linear-gradient(
    180deg,
    #f4f9f4,
    #ffffff
  );
}

.counters {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px,1fr));
  gap: 25px;
  margin-bottom: 70px;
}

.counter-card {
  background: white;
  border-radius: var(--radius-md);
  padding: 35px 20px;
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
}

.counter-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-md);
}

.counter-number {
  display: block;
  font-size: 3rem;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 10px;
}

.counter-label {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--gray-900);
}

.counter-source {
  margin-top: 10px;
  color: var(--gray-600);
  font-size: .85rem;
}

/* ==========================================================
   BARRAS DE PROGRESSO
   ========================================================== */

.progress-section {
  background: white;
  border-radius: var(--radius-lg);
  padding: 40px;
  box-shadow: var(--shadow-sm);
}

.progress-title {
  text-align: center;
  margin-bottom: 35px;
  font-size: 1.6rem;
}

.progress-item {
  margin-bottom: 25px;
}

.progress-label {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
  font-weight: 700;
}

.progress-value {
  color: var(--primary);
}

.progress-bar-wrap {
  width: 100%;
  height: 18px;
  background: #ececec;
  border-radius: 30px;
  overflow: hidden;
}

.progress-bar {
  width: 0;
  height: 100%;
  border-radius: 30px;
  background: var(--bar-color);
  transition: width 2s ease;
}

.progress-source {
  text-align: center;
  margin-top: 20px;
  color: var(--gray-600);
  font-size: .9rem;
}

/* ==========================================================
   COMPARAÇÃO
   ========================================================== */

.comparacao {
  background: #f8faf8;
}

.comp__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px,1fr));
  gap: 30px;
  margin-top: 60px;
}

.comp__card {
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: white;
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
}

.comp__card:hover {
  transform: translateY(-10px);
  box-shadow: var(--shadow-lg);
}

.comp__card-header {
  padding: 25px;
  text-align: center;
}

.comp__card-icon {
  display: block;
  font-size: 3rem;
  margin-bottom: 15px;
}

.comp__card-title {
  font-size: 1.5rem;
  margin-bottom: 12px;
}

.comp__card-badge {
  display: inline-block;
  padding: 8px 14px;
  border-radius: 50px;
  font-size: .85rem;
  font-weight: 700;
}

.comp__card-badge--green {
  background: rgba(27,122,62,.15);
  color: var(--primary);
}

.comp__card-badge--yellow {
  background: rgba(255,193,7,.18);
  color: #8a6500;
}

.comp__card-badge--red {
  background: rgba(220,53,69,.15);
  color: var(--red);
}

.comp__card--green {
  border-top: 8px solid var(--primary);
}

.comp__card--yellow {
  border-top: 8px solid var(--secondary);
}

.comp__card--red {
  border-top: 8px solid var(--red);
}

.comp__list {
  padding: 0 30px 30px;
}

.comp__list li {
  padding: 10px 0;
  border-bottom: 1px solid #eee;
}

.comp__footer {
  padding: 25px;
  text-align: center;
  font-weight: 700;
}

.comp__footer--green {
  background: rgba(27,122,62,.08);
  color: var(--primary);
}

.comp__footer--yellow {
  background: rgba(255,193,7,.12);
  color: #8a6500;
}

.comp__footer--red {
  background: rgba(220,53,69,.08);
  color: var(--red);
}

/* ==========================================================
   GRÁFICOS
   ========================================================== */

.chart-wrap {
  margin-top: 80px;
  background: white;
  border-radius: var(--radius-lg);
  padding: 40px;
  box-shadow: var(--shadow-sm);
}

.chart-title {
  text-align: center;
  font-size: 1.6rem;
  margin-bottom: 10px;
}

.chart-subtitle {
  text-align: center;
  color: var(--gray-600);
  margin-bottom: 30px;
}

canvas {
  width: 100%;
  max-width: 100%;
}

/* ==========================================================
   REVEAL ANIMATION
   ========================================================== */

.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: 1s ease;
}

.reveal.active {
  opacity: 1;
  transform: translateY(0);
}

/* ==========================================================
   RESPONSIVO
   ========================================================== */

@media (max-width: 991px) {

  .navbar__menu {
    position: fixed;
    top: 80px;
    right: -100%;
    width: 280px;
    height: calc(100vh - 80px);
    background: #132817;
    transition: .4s;
    padding: 30px;
  }

  .navbar__menu.active {
    right: 0;
  }

  .navbar__list {
    flex-direction: column;
    gap: 20px;
  }

  .navbar__toggle {
    display: block;
  }

  .hero__stats {
    position: static;
    margin-top: 40px;
  }

  .hero {
    padding: 120px 0;
  }
}

@media (max-width: 768px) {

  .section {
    padding: 70px 0;
  }

  .progress-label {
    flex-direction: column;
    gap: 4px;
  }

  .chart-wrap,
  .progress-section {
    padding: 25px;
  }

  .intro__card,
  .counter-card {
    padding: 25px;
  }
}

@media (max-width: 480px) {

  .hero__title {
    font-size: 2.8rem;
  }

  .section-title {
    font-size: 2rem;
  }

  .btn {
    width: 100%;
  }

  .hero__actions {
    flex-direction: column;
  }
