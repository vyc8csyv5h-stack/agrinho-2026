/* ==========================================================
   TIMELINE
   ========================================================== */

.timeline__wrap{
  position:relative;
  max-width:1000px;
  margin:auto;
}

.timeline__wrap::before{
  content:"";
  position:absolute;
  left:50%;
  width:4px;
  height:100%;
  background:var(--primary);
  transform:translateX(-50%);
}

.timeline__item{
  width:50%;
  position:relative;
  padding:20px 40px;
}

.timeline__item--left{
  left:0;
}

.timeline__item--right{
  left:50%;
}

.timeline__card{
  background:white;
  padding:25px;
  border-radius:18px;
  box-shadow:var(--shadow-sm);
}

.timeline__year{
  color:var(--primary);
  font-weight:700;
}

.timeline__dot{
  width:18px;
  height:18px;
  background:var(--secondary);
  border-radius:50%;
  position:absolute;
  top:35px;
}

.timeline__item--left .timeline__dot{
  right:-9px;
}

.timeline__item--right .timeline__dot{
  left:-9px;
}

/* ==========================================================
   CURIOSIDADES
   ========================================================== */

.curio__grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
